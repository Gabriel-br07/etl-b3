# Application environment
APP_ENV=development

# Database connection URL
DATABASE_URL=postgresql://etlb3:etlb3pass@localhost:5432/etlb3

# B3 data local directory (for fallback mode)
B3_DATA_DIR=data/sample

# B3 Boletim Diário entrypoint URL
B3_BULLETIN_ENTRYPOINT_URL=https://www.b3.com.br/pt_br/market-data-e-indices/servicos-de-dados/market-data/consultas/boletim-diario/boletim-diario-do-mercado/

# Optional: direct URL templates (if known)
# B3_INSTRUMENTS_URL_TEMPLATE=
# B3_TRADES_URL_TEMPLATE=

# Logging
LOG_LEVEL=INFO

# API metadata
API_TITLE=ETL B3 API
API_VERSION=0.1.0

# ------------------------------------------------------------------
# Playwright scraper settings
# ------------------------------------------------------------------

# Scraper output directories
B3_OUTPUT_DIR=data/raw
B3_SCREENSHOTS_DIR=data/screenshots
B3_TRACE_DIR=data/traces

# Browser behaviour
# PLAYWRIGHT_HEADLESS=false   → show browser (recommended for development)
# PLAYWRIGHT_HEADLESS=true    → run headless (CI/production)
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=0          # ms between actions; 300-800 is good for watching
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_DOWNLOADS_DIR=data/raw

# Playwright explicit pauses (ms)
# Pause right after opening the entrypoint page to allow dynamic content to render
PLAYWRIGHT_PAUSE_AFTER_OPEN_MS=2000
# Pause before scraping "Renda Variável" content to allow it to fully render
PLAYWRIGHT_PAUSE_BEFORE_RENDA_VARIAVEL_MS=2000

PWDEBUG=1