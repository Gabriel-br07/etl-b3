# =============================================================================
# .env.example — copy to .env and fill in secrets before running
# =============================================================================
# This file is safe to commit.  Never commit the real .env.
#
# Docker services read environment from compose.yaml and from the auto-loaded
# .env file. Values set directly in compose.yaml > environment: override values
# from this file. For the API container, DATABASE_URL is set in compose.yaml to
# use the db service (postgresql://...@db:5432/etlb3). Copy to .env for local
# (non-Docker) runs and adjust DATABASE_URL if needed.
# =============================================================================

# Application environment (development | production)
APP_ENV=development

# ------------------------------------------------------------------
# Timezone
# ------------------------------------------------------------------
# Used by all containers.  Must be a valid tz database name.
TZ=America/Sao_Paulo

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
# Credentials for a Postgres instance used in local or external setups.
# The current compose.yaml in this repo does NOT define a db service or
# automatically consume these variables; they are provided for your own
# Postgres deployment (Docker or otherwise).
POSTGRES_USER=etlb3
POSTGRES_PASSWORD=etlb3pass
POSTGRES_DB=etlb3

# Local / non-Docker development:
DATABASE_URL=postgresql://etlb3:etlb3pass@localhost:5432/etlb3
# When running under Docker, set/override DATABASE_URL explicitly in compose.yaml.
# The compose.yaml scheduler service already sets:
#   DATABASE_URL=postgresql://etlb3:etlb3pass@db:5432/etlb3

# Individual components (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=etlb3
# DB_USER=etlb3
# DB_PASSWORD=etlb3pass

# Connection pool tuning
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800   # recycle connections after 30 min (prevents stale-connection errors)

# ------------------------------------------------------------------
# Migrations
# ------------------------------------------------------------------
# Auto-run `alembic upgrade head` when the scheduler container starts.
# Set to "false" to manage migrations manually.
RUN_MIGRATIONS_ON_STARTUP=true

# ------------------------------------------------------------------
# B3 data directories
# ------------------------------------------------------------------
B3_DATA_DIR=data/sample          # local fallback mode (points at sample fixtures)
B3_OUTPUT_DIR=data/raw
B3_SCREENSHOTS_DIR=data/screenshots
B3_TRACE_DIR=data/traces

# ------------------------------------------------------------------
# B3 source URLs
# ------------------------------------------------------------------
B3_BULLETIN_ENTRYPOINT_URL=https://www.b3.com.br/pt_br/market-data-e-indices/servicos-de-dados/market-data/consultas/boletim-diario/boletim-diario-do-mercado/

# Optional: direct URL templates (avoids the browser scrape if known)
# B3_INSTRUMENTS_URL_TEMPLATE=
# B3_TRADES_URL_TEMPLATE=

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------------
# API metadata
# ------------------------------------------------------------------
API_TITLE=ETL B3 API
API_VERSION=0.1.0

# ------------------------------------------------------------------
# Playwright browser settings
# ------------------------------------------------------------------
# For local development (outside Docker) set PLAYWRIGHT_HEADLESS=false
# to see the browser.  Inside Docker (scraper_daily) this is always true.
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=0           # ms between actions; 300-800 is good for watching
PLAYWRIGHT_TIMEOUT_MS=30000


# Playwright explicit pauses (ms)
PLAYWRIGHT_PAUSE_AFTER_OPEN_MS=2000
PLAYWRIGHT_PAUSE_BEFORE_RENDA_VARIAVEL_MS=1500
PLAYWRIGHT_PAUSE_BETWEEN_ACTIONS_MS=800

# Playwright browser installation path.
#   Inside Docker  → /ms-playwright  (baked into docker/Dockerfile.scraper_daily)
#   Locally        → leave unset to use Playwright's default (~/.cache/ms-playwright)
# PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# ------------------------------------------------------------------
# Prefect serve (see docs/etl_canonical_runtime.md)
# ------------------------------------------------------------------
# PREFECT_DAILY_REGISTRY_CRON=0 8 * * *     # cadastro+negócios (default 08:00 in America/Sao_Paulo)
# PREFECT_INTRADAY_INTERVAL_MINUTES=30
# PREFECT_SERVE_INTRADAY=true               # set false to register only daily-registry
# PREFECT_RUN_COTAHIST=false                # combined/manual flow only (not default serve)

# ------------------------------------------------------------------
# B3 quote window for intraday flow (update when B3 publishes new hours)
# ------------------------------------------------------------------
# B3_EQUITIES_SESSION_OPEN=10:00
# B3_EQUITIES_SESSION_CLOSE=17:00
# B3_QUOTE_WINDOW_PADDING_BEFORE_MINUTES=10
# B3_QUOTE_WINDOW_PADDING_AFTER_MINUTES=10
# B3_MARKET_TIMEZONE=America/Sao_Paulo

# ------------------------------------------------------------------
# Stack bootstrap (scheduler entrypoint before prefect serve)
# ------------------------------------------------------------------
# RUN_STACK_BOOTSTRAP=true
# STACK_BOOTSTRAP_MARKER=/app/data/.bootstrap_light_v1.done
# FORCE_STACK_BOOTSTRAP=false
# SKIP_STACK_BOOTSTRAP_IF_FRESH=true   # skip Playwright bootstrap if today’s cadastro CSV exists

# ------------------------------------------------------------------
# Full-stack / COTAHIST wrapper (Compose service cotahist — profile full)
# ------------------------------------------------------------------
# RUN_FULL_STACK_BOOTSTRAP=true
# STACK_FULL_BOOTSTRAP_MARKER=/app/data/.bootstrap_full_v1.done
# FORCE_FULL_STACK_BOOTSTRAP=false
# COTAHIST_WORKER_SCRIPT=/app/docker/cotahist_worker.py

# ------------------------------------------------------------------
# CSV discovery (scrapers / resolvers)
# ------------------------------------------------------------------
# RETRY_COUNT=3
# RETRY_DELAY_SECONDS=60

# ------------------------------------------------------------------
# Legacy loop only (scripts/legacy_scheduler.py — do not use with Prefect)
# ------------------------------------------------------------------
# SCRAPER_INTERVAL_SECONDS=1800
# DAILY_RUN_HOUR=20
# DAILY_RUN_MINUTE=0
# RUN_MIGRATIONS_ON_STARTUP=true

# ------------------------------------------------------------------
# B3 quote batch (DailyFluctuationHistory API)
# ------------------------------------------------------------------
B3_QUOTE_BASE_URL=https://cotacao.b3.com.br/mds/api/v1
B3_QUOTE_TIMEOUT=15.0
B3_QUOTE_HTTP2=false
B3_QUOTE_CACHE_TTL=300
B3_QUOTE_MAX_RETRIES=3

# ------------------------------------------------------------------
# Playwright Inspector (local debug only — do NOT set in production)
# ------------------------------------------------------------------
# PWDEBUG=1

# ------------------------------------------------------------------
# E2E tests (pytest tests/e2e — optional)
# ------------------------------------------------------------------
# Base URL of a running API (e.g. uvicorn or docker compose up).
# E2E tests skip when unset.
# E2E_BASE_URL=http://127.0.0.1:8000

