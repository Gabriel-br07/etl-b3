# =============================================================================
# Copy to `.env` and adjust. Do not commit `.env`.
# Docker/Prefect/COTAHIST details: docs/architecture.md and compose.yaml
# =============================================================================

APP_ENV=development

# Timezone for containers (compose sets this on services; optional for local-only)
TZ=America/Sao_Paulo

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
# Used by compose for the `db` service image. For apps on the host, set DATABASE_URL.
POSTGRES_USER=etlb3
POSTGRES_PASSWORD=etlb3pass
POSTGRES_DB=etlb3

DATABASE_URL=postgresql://etlb3:etlb3pass@localhost:5432/etlb3

# Connection pool (read by app; compose also sets these on scheduler/api)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# Docker compose overrides DATABASE_URL to postgresql://...@db:5432/etlb3 inside containers.

# ------------------------------------------------------------------
# B3 paths and URLs
# ------------------------------------------------------------------
# Pydantic default for B3_DATA_DIR alone is data/sample (fixtures). Scrapers write
# to B3_OUTPUT_DIR (default data/raw). For scrape → ETL/API/scripts, keep both on
# the same tree (usually data/raw) so loads see new files.
B3_DATA_DIR=data/raw
B3_OUTPUT_DIR=data/raw
# Demo/fixtures only:
# B3_DATA_DIR=data/sample
B3_SCREENSHOTS_DIR=data/screenshots
B3_TRACE_DIR=data/traces

B3_BULLETIN_ENTRYPOINT_URL=https://www.b3.com.br/pt_br/market-data-e-indices/servicos-de-dados/market-data/consultas/boletim-diario/boletim-diario-do-mercado/
# B3_INSTRUMENTS_URL_TEMPLATE=
# B3_TRADES_URL_TEMPLATE=

# COTAHIST on disk (optional; default matches app/core/config.py)
# B3_COTAHIST_ANNUAL_DIR=data/raw/b3/cotahist_annual

# ------------------------------------------------------------------
# B3 quote HTTP client (DailyFluctuationHistory — see app/core/config.py)
# ------------------------------------------------------------------
B3_QUOTE_BASE_URL=https://cotacao.b3.com.br/mds/api/v1
B3_QUOTE_TIMEOUT=15.0
B3_QUOTE_HTTP2=false
B3_QUOTE_CACHE_TTL=300
B3_QUOTE_MAX_RETRIES=3

# ------------------------------------------------------------------
# Logging and API metadata
# ------------------------------------------------------------------
LOG_LEVEL=INFO
API_TITLE=ETL B3 API
API_VERSION=0.1.0

# ------------------------------------------------------------------
# Playwright (scrapers)
# ------------------------------------------------------------------
# Local dev: PLAYWRIGHT_HEADLESS=false to see the browser. Docker images use true.
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=0
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_DOWNLOADS_DIR=data/raw

PLAYWRIGHT_PAUSE_AFTER_OPEN_MS=3000
PLAYWRIGHT_PAUSE_BEFORE_RENDA_VARIAVEL_MS=1500
PLAYWRIGHT_PAUSE_BETWEEN_ACTIONS_MS=800

# Optional: browser bundle path inside CI/Docker images
# PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# ------------------------------------------------------------------
# Optional — not read by app code unless noted
# ------------------------------------------------------------------
# Migrations: docker/entrypoint.sh runs alembic (not Settings)
# RUN_MIGRATIONS_ON_STARTUP=true

# Prefect serve (defaults often set in compose.yaml)
# PREFECT_DAILY_REGISTRY_CRON=0 8 * * *
# PREFECT_INTRADAY_INTERVAL_MINUTES=30

# Intraday quote window (intraday flow skips outside window)
# B3_EQUITIES_SESSION_OPEN=10:00
# B3_EQUITIES_SESSION_CLOSE=17:00
# B3_QUOTE_WINDOW_PADDING_BEFORE_MINUTES=10
# B3_QUOTE_WINDOW_PADDING_AFTER_MINUTES=10
# B3_MARKET_TIMEZONE=America/Sao_Paulo

# Lightweight stack bootstrap before prefect serve (docker/entrypoint.sh →
# app.etl.orchestration.prefect.bootstrap). Compose may set SKIP_STACK_BOOTSTRAP_IF_FRESH.
# RUN_STACK_BOOTSTRAP=true
# STACK_BOOTSTRAP_MARKER=              # default: .bootstrap_light_v1.done in parent of B3_DATA_DIR
# FORCE_STACK_BOOTSTRAP=false
# SKIP_STACK_BOOTSTRAP_IF_FRESH=true

# CSV retry (compose may set these)
# RETRY_COUNT=3
# RETRY_DELAY_SECONDS=60

# COTAHIST one-shot service (profile full) — see docs/architecture.md
# RUN_FULL_STACK_BOOTSTRAP=true
# STACK_FULL_BOOTSTRAP_MARKER=/app/data/.bootstrap_full_v1.done
# FORCE_FULL_STACK_BOOTSTRAP=false

# pytest e2e (skipped when unset)
# E2E_BASE_URL=http://127.0.0.1:8000

# Playwright inspector — local only, never production
# PWDEBUG=1
